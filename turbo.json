{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "SKIP_ENV_VALIDATION",
    "DATABASE_URL",
    "TEST_DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "NEXT_PUBLIC_AUTH_URL",
    "NEXT_PUBLIC_API_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "RESEND_API_KEY",
    "RESEND_FROM",
    "CLOUDINARY_URL",
    "PORT",
    "BASE_URL",
    "LOGGER_LEVEL",
    "WEB_ORIGIN",
    "CI"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "check-types"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {},
    "db:migrate": {},
    "db:seed-dev": {
      "cache": false
    },
    "db:seed-demo": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
