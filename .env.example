# ─── Runtime ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
BASE_URL=http://localhost:8000
LOGGER_LEVEL=debug

# Used by the API's CORS allowlist + by Caddy's app subdomain. Set this
# to the deployed app origin in production.
WEB_ORIGIN=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sensus
# A sibling DB used by integration tests in packages/database.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sensus_test

# When running docker-compose.prod.yml, these are also read by the
# postgres service to provision the volume on first boot.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=sensus

# ─── Web → API ────────────────────────────────────────────────────────
# The tRPC URL the browser bundle calls. In production this should be
# the public API subdomain, e.g. https://api.<your-domain>/trpc
NEXT_PUBLIC_API_URL=http://localhost:8000/trpc

# ─── Better Auth (creator email + Google OAuth) ───────────────────────
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
# In production: https://app.<your-domain>
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_URL=http://localhost:3000

# Google OAuth, optional. Create at https://console.cloud.google.com/
# Authorised redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Rate limiting (Upstash Redis) ────────────────────────────────────
# Optional. When unset the API falls back to an in-memory sliding window
# (single-process). Required for multi-instance deployments.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Salt for SHA-256-hashing client IPs before they reach the database
# or rate-limit keys. Use a long random value in production.
IP_HASH_SALT=change-me-please

# ─── Email (Resend) ───────────────────────────────────────────────────
# Optional. When unset, the email service logs payloads instead of
# sending. Set both to enable real transactional email.
RESEND_API_KEY=
RESEND_FROM="Sensus <noreply@your-domain.tld>"

# ─── Image upload (Cloudinary) ────────────────────────────────────────
# Optional. Used for form logo + cover uploads.
CLOUDINARY_URL=

# ─── Deploy ───────────────────────────────────────────────────────────
# Used by docker-compose.prod.yml + Caddy. Set DOMAIN to the registered
# domain (without subdomain). Caddy will provision TLS for app.<DOMAIN>
# and api.<DOMAIN> on first boot.
DOMAIN=your-domain.tld
ADMIN_EMAIL=admin@your-domain.tld
