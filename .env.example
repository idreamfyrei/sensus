NODE_ENV=development
PORT=8000
BASE_URL=http://localhost:8000
LOGGER_LEVEL=debug

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sensus

# tRPC URL the web app talks to
NEXT_PUBLIC_API_URL=http://localhost:8000/trpc

# Better Auth (creator auth: email/password + Google OAuth)
# Generate a strong secret with: `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_URL=http://localhost:3000

# Google OAuth credentials — create at https://console.cloud.google.com/
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
